{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "types",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "lib": ["ES2022", "DOM"],
    "jsx": "react",
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["src/**/*.js"]
}
